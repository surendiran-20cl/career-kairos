# Copy this file to .env in the same folder (backend/.env) and fill
# in your own values. Never commit the real .env file to GitHub -
# it's already covered by .gitignore.

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Port 5433 here matches the docker-compose.yml mapping (host 5433
# -> container 5432), chosen to avoid clashing with a local Postgres
# install on the default port 5432.
DATABASE_URL=postgresql://resume_user:resume_pass@localhost:5433/resume_matcher

# Secret key used to sign JWT access tokens. Generate a real random
# value for this - do NOT use a guessable string in production.
# Quick way to generate one (run in Python):
#   import secrets; print(secrets.token_hex(32))
SECRET_KEY=change_this_to_a_long_random_string_later

# How long a login token stays valid, in minutes, before the user
# has to log in again.
ACCESS_TOKEN_EXPIRE_MINUTES=30
